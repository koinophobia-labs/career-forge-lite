# Career Forge environment — see docs/PAYMENTS.md for the full setup guide.
# With everything unset the app runs as the free beta: no gates, no buy buttons.

# --- Commerce (all optional) -------------------------------------------------
# off (default) | test | live — gates + buy buttons activate when not "off".
NEXT_PUBLIC_COMMERCE_MODE=off

# Invite-only live commerce opens one tier at a time. Test mode may exercise all
# tiers; live mode defaults to Career Reset unless both values are changed.
PAID_BETA_TIER=reset
NEXT_PUBLIC_PAID_BETA_TIER=reset

# Stripe secret key (sk_test_… for test mode, sk_live_… for live).
STRIPE_SECRET_KEY=

# Only needed if the license-email webhook is configured in Stripe.
STRIPE_WEBHOOK_SECRET=

# License signing keypair — generate with: node scripts/generate-license-keys.mjs
# Use DIFFERENT keypairs for test and live environments.
LICENSE_SIGNING_PRIVATE_KEY=
NEXT_PUBLIC_LICENSE_PUBLIC_KEY=

# Canonical origin used in checkout success/cancel URLs.
NEXT_PUBLIC_APP_URL=

# Optional license-key backup email (Resend).
RESEND_API_KEY=
LICENSE_EMAIL_FROM=
