# Career Forge environment — see docs/PAYMENTS.md for the full setup guide.
# With everything unset the app runs as the free beta: no gates, no buy buttons.

# --- Commerce (all optional) -------------------------------------------------
# off (default) | test | live — gates + buy buttons activate when not "off".
NEXT_PUBLIC_COMMERCE_MODE=off

# Test mode may exercise package gates. Production fails closed unless both
# values remain `reset`; the $79 and $99 tiers are not live offers.
PAID_BETA_TIER=reset
NEXT_PUBLIC_PAID_BETA_TIER=reset

# Stripe secret key (sk_test_… for test mode, sk_live_… for live).
STRIPE_SECRET_KEY=

# Authoritative one-time Stripe Price ID for the $49 Career Reset package.
STRIPE_PRICE_RESET=

# Deprecated legacy Payment Link. Runtime checkout ignores this value.
STRIPE_LIVE_RESET_PAYMENT_LINK=

# Required Stripe endpoint signing secret for license fulfillment.
STRIPE_WEBHOOK_SECRET=

# License signing keypair — generate with: node scripts/generate-license-keys.mjs
# Use DIFFERENT keypairs for test and live environments.
LICENSE_SIGNING_PRIVATE_KEY=
NEXT_PUBLIC_LICENSE_PUBLIC_KEY=

# Canonical origin used in checkout success/cancel URLs.
NEXT_PUBLIC_APP_URL=

# Required license fulfillment email (Resend).
RESEND_API_KEY=
LICENSE_EMAIL_FROM=
LICENSE_EMAIL_REPLY_TO=

# Short-lived production-host test certification. Set only during the drill;
# removing any one disables the operator route and the test Stripe path.
CERTIFICATION_STRIPE_SECRET_KEY=
CERTIFICATION_STRIPE_PRICE_RESET=
CERTIFICATION_STRIPE_WEBHOOK_SECRET=
CERTIFICATION_OPERATOR_TOKEN=
